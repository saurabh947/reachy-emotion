# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Required: Google Gemini API key
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required: emotion-cloud gRPC endpoint (GKE LoadBalancer external IP + port)
# Run: kubectl get svc emotion-cloud-grpc -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
EMOTION_CLOUD_ENDPOINT=your_gke_ip:50051

# Optional: override the default Gemini model (default: gemini-2.5-flash)
# Other options: gemini-2.5-flash-lite (cheaper), gemini-2.5-pro (smarter, pricier)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: custom system prompt (single line, will override the default)
# GEMINI_SYSTEM_PROMPT=You are Reachy, a friendly robot. Be concise and warm.
